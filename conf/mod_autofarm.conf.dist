[worldserver]

#
# mod-autofarm
# Server-side material farming coordinator for characters controlled by mod-playerbots.
#

# Enable the module and its .autofarm commands.
# Default: 1
Autofarm.Enable = 1

# Teleport a bot to the first point of the selected farming route.
# Default: 1
Autofarm.TeleportToRoute = 1

# Return the bot to its original location when stopped or when its quantity goal is reached.
# Default: 1
Autofarm.ReturnOnStop = 1

# Prevent playerbots from eating, drinking, or repeatedly refreshing class buffs while autofarming.
# Health and mana are restored out of combat so creature farming does not stall between fights.
# The bot's original food, buff, and grind strategies are restored when the session stops.
# Default: 1
Autofarm.SuppressRestAndBuffs = 1

# Make bots and their active pets immune to NPC and player-controlled combat on routes made entirely from mining or
# herbalism nodes. This does not hide them from players, prevent node interaction, or affect creature-loot/skinning
# routes. Prior immunity states and combat strategies are restored when the session stops.
# Default: 1
Autofarm.PassiveNodeGathering = 1

# Keep an autofarming character out of AFK state and refresh its server session activity timer.
# Playerbots have no client keyboard to press, so this is the server-side equivalent of periodic input.
# Set to 0 to disable. Non-zero values below 10000 are raised to 10000 milliseconds.
# Default: 60000
Autofarm.KeepAliveIntervalMs = 60000

# Use a known flying mount or flight form for route travel in Outland and Northrend.
# The bot takes off for travel, lands only at the selected source, and ignores unrelated
# combat while still airborne. Normal combat is restored if it is forced off the mount.
# Default: 1
Autofarm.UseFlyingMounts = 1

# Minimum cruising clearance above the highest sampled terrain between route points, in yards.
# Range: 15-100
# Default: 35
Autofarm.FlightHeight = 35

# Skip a dangerous route point after remaining in unrelated combat while airborne for this long.
# This lets the bot fly away instead of hovering indefinitely over an attacker.
# Default: 6000
Autofarm.FlightCombatEscapeMs = 6000

# Maps that may be selected for outdoor farming. Empty means the four WotLK outdoor continents.
# Default: "0,1,530,571"
Autofarm.AllowedMaps = "0,1,530,571"

# Zone-spread scale used when comparing otherwise similar farming zones, in yards.
# This does not limit the selected route to a subsection of the zone.
# Default: 1800
Autofarm.ClusterSize = 1800

# Nearest-source distance ceiling used while scoring candidate zones, in yards.
# This does not exclude source points from the selected zone.
# Default: 2800
Autofarm.ClusterRadius = 2800

# Maximum spawn points kept in one route. If a zone has more points, they are distributed across the whole zone.
# The route is optimized into a closed loop when complete.
# Default: 300
Autofarm.MaxRoutePoints = 300

# Do not deliberately farm normal creatures more than this many levels above the bot.
# Default: 3
Autofarm.MaxCreatureLevelsAboveBot = 3

# Manager update interval, in milliseconds.
# Default: 1000
Autofarm.UpdateIntervalMs = 1000

# Give a node or corpse this long to finish looting/gathering before continuing, in milliseconds.
# Default: 15000
Autofarm.InteractionTimeoutMs = 15000

# Skip a route point when travel has made no useful progress for this long, in milliseconds.
# Default: 120000
Autofarm.RoutePointTimeoutMs = 120000

# Emit route and interaction diagnostics.
# Default: 0
Autofarm.Debug = 0
